{
  "name": "ucp-client",
  "version": "1.0.0",
  "description": "UCP Client - Reference implementation of Unified Communications Protocol",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:frontend\"",
    "dev:api": "NODE_ENV=development bun --hot src/index.server.ts",
    "dev:frontend": "NODE_ENV=development bun --hot src/index.client.tsx",
    "build": "bun run build.ts",
    "start": "NODE_ENV=production bun src/index.server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest",
    "drizzle-orm": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "concurrently": "latest"
  }
}
