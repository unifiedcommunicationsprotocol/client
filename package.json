{
  "name": "ucp-client",
  "version": "1.0.0",
  "description": "UCP Client - Reference implementation of Unified Communications Protocol",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --hot src/index.server.ts",
    "build": "bun run build.ts",
    "start": "NODE_ENV=production bun src/index.server.ts",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest",
    "drizzle-orm": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "concurrently": "latest"
  }
}
